# Authentication System - Environment Configuration
# Copy this to .env and fill in your values

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/auth_db
DB_POOL_SIZE=10
DB_POOL_TIMEOUT=30
DB_MAX_OVERFLOW=5
DB_QUERY_TIMEOUT=10

# ============================================
# JWT Configuration
# ============================================
# IMPORTANT: Generate a secure secret key!
# You can use: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# Email Configuration (for password reset)
# ============================================
# For Gmail, use an App Password: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_USE_TLS=true

# ============================================
# Rate Limiting Configuration
# ============================================
# Login: 10 attempts per 60 seconds
RATE_LIMIT_LOGIN=10
RATE_LIMIT_LOGIN_WINDOW=60

# Registration: 5 attempts per 60 seconds
RATE_LIMIT_REGISTER=5
RATE_LIMIT_REGISTER_WINDOW=60

# Password Reset: 3 attempts per 300 seconds (5 minutes)
RATE_LIMIT_RESET=3
RATE_LIMIT_RESET_WINDOW=300

# ============================================
# Circuit Breaker Configuration
# ============================================
# Email service circuit breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60

# ============================================
# Security Configuration
# ============================================
MIN_PASSWORD_LENGTH=8
REQUIRE_UPPERCASE=true
REQUIRE_LOWERCASE=true
REQUIRE_DIGIT=true
REQUIRE_SPECIAL_CHAR=false

# Bcrypt rounds (higher = more secure but slower)
BCRYPT_ROUNDS=12

# Password reset token expiry (in hours)
RESET_TOKEN_EXPIRE_HOURS=1

# ============================================
# Application Configuration
# ============================================
DEBUG=false
ENVIRONMENT=development

# ============================================
# Quick Setup Instructions
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Generate JWT secret: python -c "import secrets; print(secrets.token_hex(32))"
# 3. Update SMTP settings with your email provider
# 4. Create database: createdb auth_db
# 5. Run: python api.py
